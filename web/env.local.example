# 오뉴 환경변수 예시 파일
# 실제 사용 시 이 파일을 .env.local로 복사하여 값을 채워주세요.
# .env.local은 .gitignore에 의해 커밋되지 않습니다.

# ============================================================
# 이메일 암호화 (AES-256-CBC, 반드시 정확히 32자)
# ============================================================

# 현재 암호화 키 (새 키)
ENCRYPTION_KEY=caa19df32a1a1aaf556ce6227a3b3360

# 이전 암호화 키 (마이그레이션 완료 후 제거)
# 2026-02-11 보안 강화 전 하드코딩되어 있던 기본 키
LEGACY_ENCRYPTION_KEY=12345678901234567890123456789012

# ============================================================
# Firebase
# ============================================================
# 로컬 개발 시 서비스 계정 파일 경로 (선택)
# SERVICE_ACCOUNT_PATH=./service-account.json

# ============================================================
# 어드민
# ============================================================
ADMIN_PASSWORD=your_admin_password_here

# ============================================================
# Gmail SMTP (뉴스레터 발송)
# ============================================================
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# ============================================================
# Amplitude (분석)
# ============================================================
NEXT_PUBLIC_AMPLITUDE_API_KEY=your_amplitude_api_key
