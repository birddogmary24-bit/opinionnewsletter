# ============================================
# 오뉴 뉴스레터 환경변수 설정 가이드
# ============================================
# 이 파일을 .env.local 로 복사한 후 값을 채워주세요:
#   cp .env.example .env.local
#
# Cloud Run 배포 시에는 deploy.sh 스크립트를 사용하세요.
# ============================================

# [필수] Gmail 설정 - 이메일 발송용
# 1. Gmail 계정에서 2단계 인증을 활성화하세요
#    https://myaccount.google.com/security > 2단계 인증
# 2. 앱 비밀번호를 생성하세요
#    https://myaccount.google.com/apppasswords
#    - 앱: "메일", 기기: "기타(맞춤 이름)" > "오뉴 뉴스레터"
#    - 생성된 16자리 비밀번호를 아래에 입력
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# [필수] 암호화 키 - 이메일 암호화 저장용 (정확히 32자)
# 아래 명령어로 생성 가능:
#   node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=00000000000000000000000000000000

# [필수] 관리자 비밀번호 - /admin 로그인용
ADMIN_PASSWORD=your-admin-password

# [필수] 크론 시크릿 키 - 자동 이메일 발송 인증용
# Cloud Scheduler에서 이 값을 헤더로 전송합니다
# 아래 명령어로 생성 가능:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-cron-secret-key

# [선택] Firebase 서비스 계정 (로컬 개발용)
# Cloud Run에서는 자동으로 ADC를 사용하므로 불필요
SERVICE_ACCOUNT_PATH=./service-account.json

# [선택] Amplitude 분석
NEXT_PUBLIC_AMPLITUDE_API_KEY=your-amplitude-key
